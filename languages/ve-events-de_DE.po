# v1.8.0 – OG-Tags
msgid "Open Graph / Social Meta Tags"
msgstr "Open Graph / Social-Meta-Tags"

msgid ""
"Outputs og: and twitter: meta tags on single event pages for social sharing "
"previews."
msgstr ""
"Gibt og:- und twitter:-Meta-Tags auf einzelnen Event-Seiten für Social-"
"Sharing-Vorschauen aus."

